# 复制为 .env.local 后填入实际值

# ─── AI 推理（DeepSeek V4 Pro）───
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro

# ─── 站点 ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 获取 API Key: https://platform.deepseek.com/
# 模型说明:
#   deepseek-v4-pro    — 最强模型（1.6T 参数，thinking 模式，推荐）
#   deepseek-v4-flash  — 快速版（284B 参数，低成本）
#   deepseek-chat      — 旧别名（→ V4-Flash 非思考），2026/07/24 退役
#   deepseek-reasoner  — 旧别名（→ V4-Flash 思考），2026/07/24 退役
